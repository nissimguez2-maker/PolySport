{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Phase 1 Logger",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/phase1_logger.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Dashboard (FastAPI live-reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "polysport.dashboard.app:app",
        "--reload",
        "--port",
        "8000"
      ],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Pytest: Current File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-vv", "-s"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Pytest: All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-vv"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Audit: state",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/audit_state.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Audit: ghosts",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/audit_state2.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    }
  ]
}
