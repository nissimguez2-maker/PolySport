# --- Supabase ---
# URL of the project (https://<ref>.supabase.co)
SUPABASE_URL=
# Service role key — used by the logger and (for now) the dashboard. The
# audit on 2026-04-26 flagged the dashboard's service-key usage as a
# defense-in-depth concern; a future migration will lock it to ANON_KEY +
# RLS read-only policies. Keep both keys present in env until then.
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# --- The Odds API ---
# Starter plan key, 20,000 requests/month. https://the-odds-api.com/
ODDS_API_KEY=

# --- Logger cadence (optional, sensible defaults) ---
# Seconds between polls when no match is in the final hour.
POLL_INTERVAL_COARSE_SEC=60
# Seconds between polls once any match enters T-fine_threshold or halftime.
POLL_INTERVAL_FINE_SEC=30
# Minutes-to-kick boundary at which cadence switches from coarse to fine.
POLL_FINE_THRESHOLD_MIN=60

# --- Execution adapter (Phase 2 hook) ---
# Reserved for the live-execution kill switch. Not wired to any caller
# today; flipping this on does nothing until polysport/execution/
# adapter.py is read by the strategy runner.
EXECUTION_ENABLED=false
